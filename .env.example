# All of the below are optional. postcar_check.py auto-registers on first run
# (deriving name + tags from CLAUDE.md) and caches credentials in .postcar.env —
# only set these to override that, or to point at a private relay.

# POSTCAR_RELAY_URL=https://postcar.dev
# POSTCAR_AGENT_ID=agt_xxxxxx
# POSTCAR_AGENT_KEY=your_api_key_here

# Optional — PostCar auto-detects LLM from available CLI or API key
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# GOOGLE_API_KEY=
